export WORKSPACES_ROOT=${HOME}/workspaces

# copy from ${MUJINJH_APPCONTROLLER_HOME}/setuptestdev.bash
setuptestdev() {
    APPCONTROLLER_SCRIPT_PATH=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
    export MUJINJH_APPCONTROLLER_HOME=$APPCONTROLLER_SCRIPT_PATH
    if [ -z $MUJIN_JHBUILD_CHECKOUT_DIR ]; then
        export MUJIN_APPCONTROLLER_HOME=$MUJINJH_APPCONTROLLER_HOME/checkoutroot/appcontroller
    else
        export MUJIN_APPCONTROLLER_HOME=$MUJIN_JHBUILD_CHECKOUT_DIR/appcontroller
    fi

    # path
    export PATH=$MUJINJH_APPCONTROLLER_HOME/install/bin:$MUJINJH_APPCONTROLLER_HOME/install/devbin:$MUJINJH_APPCONTROLLER_HOME/install/development/bin:$PATH

    # pythonpath
    MUJININSTALL_PYTHONPATH=`python -c "from distutils.sysconfig import get_python_lib; print(':'.join([get_python_lib(1,prefix='$MUJINJH_APPCONTROLLER_HOME/install'),get_python_lib(1,prefix='$MUJINJH_APPCONTROLLER_HOME/install/development')]))"`
    # some libraries like opencv don't respect standards and always save into dist-packages, therefore have to add it to the path
    MUJININSTALL_PYTHONPATH=$MUJININSTALL_PYTHONPATH:`python -c "print('$MUJININSTALL_PYTHONPATH'.replace('site','dist'))"`
    # export PYTHONPATH=$MUJININSTALL_PYTHONPATH:$PYTHONPATH

    # ld
    export LD_LIBRARY_PATH=$MUJINJH_APPCONTROLLER_HOME/install/lib:$MUJINJH_APPCONTROLLER_HOME/install/development/lib:/usr/local/lib:$LD_LIBRARY_PATH

    # pkgconfig
    export PKG_CONFIG_PATH=$MUJINJH_APPCONTROLLER_HOME/install/lib/pkgconfig:$MUJINJH_APPCONTROLLER_HOME/install/development/lib/pkgconfig:$PKG_CONFIG_PATH

    # cmake
    export CMAKE_PREFIX_PATH=$MUJINJH_APPCONTROLLER_HOME/install:$MUJINJH_APPCONTROLLER_HOME/install/development:$CMAKE_PREFIX_PATH

    export MUJIN_INSTALL_DIR=$MUJINJH_APPCONTROLLER_HOME/install
    # source setuprepoenv.bash
    source /home/mujin/workspaces/master/jhbuildcommon/jhbuild/contrib/jhbuild_completion.bash
    if [[ ! $MUJIN_JHBUILD_CHECKOUT_DIR ]]; then
    realcheckoutroot=$(readlink -f $MUJINJH_APPCONTROLLER_HOME/checkoutroot)
    elif [[ -L $MUJIN_JHBUILD_CHECKOUT_DIR ]]; then
    realcheckoutroot=$(readlink -f $MUJIN_JHBUILD_CHECKOUT_DIR)
    else
    realcheckoutroot=$MUJIN_JHBUILD_CHECKOUT_DIR
    fi
    for filename in $(find $realcheckoutroot -maxdepth 3 -name setuprepoenv.bash); do
        export PYTHONPATH=$(dirname $filename)/python:$PYTHONPATH
        export PATH=$(dirname $filename)/bin:$(dirname $filename)/devbin:$PATH
        source $filename
        case $- in
            *i*) ;;
            *) continue;;
        esac
        result=$?
        if [ $result -gt 0 ]; then
            echo "failed to source $filename"
        else
            echo "sourced $filename"
        fi
    done

}

mujin_workspace_make() {
    CURRENT_WORKING_DIR=$(pwd)
    MUJIN_WORKSPACE_ID=$1

    if [ -d ${WORKSPACES_ROOT}/${MUJIN_WORKSPACE_ID} ]; then
        echo "Workspace exists"
        return 1
    fi

    mkdir -p ${WORKSPACES_ROOT}/${MUJIN_WORKSPACE_ID}/checkoutroot
    cd ${WORKSPACES_ROOT}/${MUJIN_WORKSPACE_ID}

    echo MUJIN_WORKSPACE_SHORTDESC="$MUJIN_WORKSPACE_ID" > ${WORKSPACES_ROOT}/${MUJIN_WORKSPACE_ID}/workspaceinfo

    git clone git@git.mujin.co.jp:jhbuild/jhbuildcommon.git
    git clone git@git.mujin.co.jp:jhbuild/jhbuildappcontroller.git
    mujin_workspace_set ${MUJIN_WORKSPACE_ID}
    mujin_jhbuildcommon_updatejhbuildcommon.bash
    cd ${MUJINJH_APPCONTROLLER_HOME}
    mujin_jhbuildcommon_initjhbuild.bash
    jhbuild sysdeps --install
    mujin_workspace_set ${MUJIN_WORKSPACE_ID}

    cd ${CURRENT_WORKING_DIR}
}

mujin_workspace_set() {
    MUJIN_WORKSPACE_ID=$1
    export MUJIN_WORKSPACE_ID=$1
    export MUJIN_CONFIG_DIR=/data/config_local
    MUJIN_WORKSPACE_ROOT=${WORKSPACES_ROOT}/${MUJIN_WORKSPACE_ID}

    # Clear previous MUJIN env variables
    unset CMAKE_PREFIX_PATH
    unset PYTHONPATH
    unset QML_IMPORT_PATH
    unset OPENRAVE_PLUGINS
    unset HDF5_PLUGIN_PATH
    unset GENICAM_GENTL64_PATH
    unset QML2_IMPORT_PATH
    unset OPENRAVE_DATA
    unset PKG_CONFIG_PATH

    unset MUJIN_SHUGO_SHARE_DIR

    unset MUJIN_TESTAPPCONTROLLER_SHARE_DIR
    unset MUJIN_RESOURCES_SHARE_DIR
    unset MUJIN_ROBOTS_SHARE_DIR
    unset QT_PLUGIN_PATH
    unset MUJIN_APPCONTROLLER_HOME
    unset MUJIN_APPFRPIECEPICKINGWITHQPS_SHARE_DIR
    unset MUJIN_TESTREGISTRATION_SHARE_DIR

    if [[ $MUJIN_WORKSPACE_ID == sub* ]]; then
        echo "work space in sub folder"
        export MUJIN_JHBUILD_CHECKOUT_DIR=${MUJIN_WORKSPACE_ROOT}/../checkoutroot
    else
        export MUJIN_JHBUILD_CHECKOUT_DIR=${MUJIN_WORKSPACE_ROOT}/checkoutroot
    fi

    MUJIN_TESTAPPCONTROLLER_SHARE_DIR=${MUJIN_JHBUILD_CHECKOUT_DIR}/appcontroller/testappcontroller
    MUJIN_RESOURCES_SHARE_DIR=${MUJIN_JHBUILD_CHECKOUT_DIR}/resources
    MUJIN_ROBOTS_SHARE_DIR=${MUJIN_JHBUILD_CHECKOUT_DIR}/robots
    QT_PLUGIN_PATH=${MUJIN_WORKSPACE_ROOT}/${MUJIN_WORKSPACE_JHBUILDAPP_NAME}/install/lib/plugins:
    MUJIN_APPCONTROLLER_HOME=${MUJIN_JHBUILD_CHECKOUT_DIR}/appcontroller
    MUJIN_APPFRPIECEPICKINGWITHQPS_SHARE_DIR=${MUJIN_JHBUILD_CHECKOUT_DIR}/appfrpiecepickingwithqps
    MUJIN_TESTREGISTRATION_SHARE_DIR=${MUJIN_JHBUILD_CHECKOUT_DIR}/registration/testregistration

    for VAR in $(printenv | grep ^MUJIN | sed -e 's/=.*$//'); do
        unset -f ${VAR}
    done
    export MUJIN_WORKSPACE_JHBUILDAPP_NAME="jhbuildappcontroller"
    echo -e "Configuring Mujin environment: \033[01;32m${MUJIN_WORKSPACE_ID}\033[00m"
    # Update .jhbuildrc
    if [ "$(diff -q ${MUJIN_WORKSPACE_ROOT}/${MUJIN_WORKSPACE_JHBUILDAPP_NAME}/.jhbuildrc ${HOME}/.jhbuildrc)" != "" ]; then
        echo "Updating ~/.jhbuildrc"
        cp ${MUJIN_WORKSPACE_ROOT}/${MUJIN_WORKSPACE_JHBUILDAPP_NAME}/.jhbuildrc ${HOME}/
    fi

    # export PYTHONPATH=/opt/lib/python2.7/site-packages:$PYTHONPATH
    export LD_LIBRARY_PATH="/usr/local/lib"
    export LD_LIBRARY_PATH=/opt/lib:$LD_LIBRARY_PATH
    unset PATH
    export PATH=$ORG_PATH:/usr/local/bin:/usr/bin:/bin:$HOME/.local/bin
    export PATH=/usr/lib/ccache:$PATH
    export PATH=/snap/bin:/usr/sbin:/sbin:${HOME}/mujin/ssh/bin:$PATH
    export PATH=/opt/bin:$PATH
    YELLOW='\033[1;33m'
    GREEN='\033[0;32m'
    RED='\033[0;31m'
    NC='\033[0m' # No Color
    display_text() {
        # $1 color
        # $2 text
        echo -e "$1$2${NC}"
    }
    log_info() {
        display_text $NC "$1"
    }
    log_debug() {
        display_text $GREEN "$1"
    }
    log_warn() {
        display_text $YELLOW "$1"
    }
    log_error() {
        display_text $RED "$1"
    }
    if [[ $PATH != *"${MUJIN_WORKSPACE_ROOT}/jhbuildcommon/bin"* ]]; then
        export PATH="${MUJIN_WORKSPACE_ROOT}/jhbuildcommon/bin:$PATH"
    fi
    export MUJINJH_COMMON=${MUJIN_WORKSPACE_ROOT}/jhbuildcommon
    if [ -f "${MUJINJH_COMMON}/jhbuild/contrib/jhbuild_completion.bash" ]; then
        source "${MUJINJH_COMMON}/jhbuild/contrib/jhbuild_completion.bash"
    fi

    PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]$(__git_ps1)\n╰─\[\033[01;32m\](workspace:${MUJIN_WORKSPACE_ID}) \[\033[00m\]$ '
    # export MUJIN_JHBUILD_CHECKOUT_DIR=${MUJIN_WORKSPACE_ROOT}/checkoutroot
    export MUJINJH_APPCONTROLLER_HOME=${MUJIN_WORKSPACE_ROOT}/${MUJIN_WORKSPACE_JHBUILDAPP_NAME}
    export D=${MUJIN_JHBUILD_CHECKOUT_DIR}/detectors/python/mujindetection/

    export MUJIN_JHBUILD_DOWNLOADS_DIR=${MUJIN_WORKSPACE_ROOT}/downloads
    
    # source ${MUJINJH_APPCONTROLLER_HOME}/setuptestdev.bash
    setuptestdev

    source ${MUJIN_WORKSPACE_ROOT}/workspaceinfo

    return 0
}

mujin_workspace_list() {
    for WS_DIR_NAME in `ls ${WORKSPACES_ROOT}`; do
        if [ -f ${WORKSPACES_ROOT}/${WS_DIR_NAME}/workspaceinfo ]; then
            WS_SHORTDESC="`grep -oP '(?<=MUJIN_WORKSPACE_SHORTDESC=)[^\n]*' ${WORKSPACES_ROOT}/${WS_DIR_NAME}/workspaceinfo`"
            echo $WS_DIR_NAME: ${WS_SHORTDESC}
        fi
    done
}
